APP_NAME=EduFlow AI API
APP_ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_REQUEST_TIMEOUT=120
LLM_MAX_OUTPUT_TOKENS=8000
LLM_TEMPERATURE=0.2
MAX_GENERATED_JSON_BYTES=262144

# Optional pricing snapshot for per-request cost estimates.
LLM_INPUT_COST_PER_1M=
LLM_CACHE_HIT_INPUT_COST_PER_1M=
LLM_OUTPUT_COST_PER_1M=
LLM_PRICING_SNAPSHOT=
TEMP_DIR=./temp
